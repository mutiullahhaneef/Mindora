# ─── App ───────────────────────────────────────────────
APP_NAME=Mindora
DEBUG=True
SECRET_KEY=your-very-strong-secret-key-here-change-in-production

# ─── Database ──────────────────────────────────────────
# Docker: postgresql+asyncpg://postgres:postgres@db:5432/mindora
# Local:  postgresql+asyncpg://postgres:postgres@localhost:5432/mindora
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mindora

# ─── Redis ─────────────────────────────────────────────
# Docker: redis://redis:6379/0
# Local:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI (OpenAI — Primary) ─────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── AI (Ollama — Offline Fallback) ───────────────────
USE_OLLAMA=False
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── File Upload ───────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── ChromaDB ──────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_storage
CHROMA_COLLECTION=mindora_documents
